# Скопируйте этот файл в .env.local и заполните значения.
# Запуск:
#   docker compose --env-file .env.local -f compose.demo.yml up -d --build
# Если любая из переменных не задана, compose упадёт с явной ошибкой
# (`is required in .env.local`).

# --- Database -----------------------------------------------------------------
# Пароль для пользователя crm_user в Postgres.
DB_PASSWORD=

# --- JWT / Auth ---------------------------------------------------------------
# Секрет для подписи JWT. Минимум 32 символа.
JWT_SECRET=

# Секрет для HMAC-хэширования OTP-кодов. Минимум 32 символа.
OTP_HASH_SECRET=

# --- Frontend build -----------------------------------------------------------
# Путь к локальному чекауту crm-web-portal (репозиторий с Dockerfile).
# Относительный путь резолвится от папки с этим .env.local.
FRONTEND_PATH=../crm_web_portal

# Публичные URL, вшиваются в бандл Next.js на этапе build.
# Для локального demo фронт и API обслуживаются Caddy на http://localhost.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=http://localhost

# --- DeepSeek-compatible LLM --------------------------------------------------
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://llms.dotpoin.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# --- Observability ------------------------------------------------------------
# Пароль admin-пользователя Grafana.
GRAFANA_ADMIN_PASSWORD=
